knitr::opts_chunk$set(echo = TRUE)
library("dplyr")
library("lubridate")
library("ggplot2")
library("tidyr")
setwd("C:/Users/Admin/Desktop/DML")
library(readr)
df <- read_csv("Scatter_Plot.csv")
print(df)
colnames(df)
df%>%
ggplot(aes(x=`math score`,y=`writing score`))+geom_point()+geom_smooth(se=FALSE)
df%>%
ggplot(aes(x=`reading score`,y=`writing score`))+geom_point()+geom_smooth(se=FALSE)
df%>%
ggplot(aes(x=`math score`,y=`reading score`))+geom_point()+facet_wrap(~gender)+geom_smooth(se=FALSE)
df%>%
filter(gender=="female")%>%
ggplot(aes(x=`writing score`,y=`reading score`))+geom_point()+
facet_wrap(~lunch)+geom_smooth(se=FALSE)
df%>%
ggplot(aes(x=`math score`,y=`reading score`))+geom_point(color="green")+
facet_wrap(~`parental level of education`)+geom_smooth(se=FALSE)
